# --- User data (lives on the SSD, never pushed) ---

# Notes: per-domain CLAUDE.md is a template (committed), the rest is user data.
content/notes/**
!content/notes/CLAUDE.md

# Communication archives: same rule.
content/communication/**
!content/communication/CLAUDE.md

# Projects: shared CLAUDE.md + per-project CLAUDE.md are templates; everything
# else under a project subdir is user code/notes and stays on the drive.
content/projects/**
!content/projects/CLAUDE.md
!content/projects/*/
!content/projects/*/CLAUDE.md
!content/projects/*/.myhub-project.toml

# Wiki is auto-generated by the compiler — articles are re-derivable, don't
# commit. Category CLAUDE.md files are templates that ship with the repo.
content/wiki/**
!content/wiki/CLAUDE.md
!content/wiki/*/
!content/wiki/*/CLAUDE.md

# Memory: index is a template, every entry below is user-learned state.
memory/**
!memory/MEMORY.md

# --- Secrets ---
.claude/.credentials.json
.claude/projects/
.claude/todos/
.claude/shell-snapshots/
.claude/statsig/

# --- Runtime binaries (shipped via GitHub Releases, not source) ---
bin/claude
bin/claude-*
bin/myhub
bin/ollama
bin/rg
bin/fswatch
# bin/myhub-tui is the Python launcher bash script — committed, not release-shipped.

# --- Build toolchains (shipped via Releases + install-*.sh bootstraps) ---
tooling/go
tooling/go-*
tooling/cache/
tooling/*.tar.gz
!tooling/README.md
!tooling/install-go.sh
!tooling/install-python.sh
!tooling/install-uv.sh

# --- SSD-portable Python runtime (bootstrapped by install-python.sh) ---
runtime/

# --- uv binary (bootstrapped by install-uv.sh) ---
bin/uv
bin/uvx

# --- Boot-time state (host-specific, generated at install) ---
.boot/trusted-hosts.json
.boot/dashboard-state.json
.boot/.respawn
.boot/repl-state.json

# --- Python build/test artifacts ---
**/__pycache__/
**/*.pyc
**/*.egg-info/
.pytest_cache/
.ruff_cache/
.mypy_cache/

# --- Go build artifacts ---
myhub-cli/bin/
myhub-cli/dist/
*.test
*.out
coverage.out

# --- Placeholder assets not yet chosen ---
.boot/assets/*.aiff
.boot/assets/*.icns
!.boot/assets/.gitkeep

# --- macOS / editor junk ---
.DS_Store
.AppleDouble
.LSOverride
._*
.idea/
.vscode/
*.swp
*.swo

# --- Logs ---
*.log

.claude/backups/
.claude/telemetry/
.claude/.claude.json
