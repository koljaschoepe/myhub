# --- User data (lives on the SSD, never pushed) ---

# Notes: per-domain CLAUDE.md is a template (committed), the rest is user data.
content/notes/**
!content/notes/CLAUDE.md

# Communication archives: same rule.
content/communication/**
!content/communication/CLAUDE.md

# Projects: shared CLAUDE.md + per-project CLAUDE.md are templates; everything
# else under a project subdir is user code/notes and stays on the drive.
content/projects/**
!content/projects/CLAUDE.md
!content/projects/*/
!content/projects/*/CLAUDE.md
!content/projects/*/.myhub-project.toml

# Wiki is auto-generated by the compiler — re-derivable, don't commit.
content/wiki/**
!content/wiki/CLAUDE.md

# Memory: index is a template, every entry below is user-learned state.
memory/**
!memory/MEMORY.md

# --- Secrets ---
.claude/.credentials.json
.claude/projects/
.claude/todos/
.claude/shell-snapshots/
.claude/statsig/

# --- Runtime binaries (shipped via GitHub Releases, not source) ---
bin/claude
bin/claude-*
bin/myhub-tui
bin/myhub
bin/ollama
bin/rg
bin/fswatch

# --- Build toolchains (shipped via Releases + install-go.sh bootstrap) ---
tooling/go
tooling/go-*
tooling/*.tar.gz
!tooling/README.md
!tooling/install-go.sh

# --- Boot-time state (host-specific, generated at install) ---
.boot/trusted-hosts.json
.boot/dashboard-state.json

# --- Go build artifacts ---
myhub-tui/bin/
myhub-tui/dist/
*.test
*.out
coverage.out

# --- Placeholder assets not yet chosen ---
.boot/assets/*.aiff
.boot/assets/*.icns
!.boot/assets/.gitkeep

# --- macOS / editor junk ---
.DS_Store
.AppleDouble
.LSOverride
._*
.idea/
.vscode/
*.swp
*.swo

# --- Logs ---
*.log
